# Formal scene-0061 reconstruction using the official NuRec 26.04 six-camera
# recipe. Copy to config/nurec-formal.env on the server. Keep NGC_API_KEY in
# the shell environment; never store it in this file.

NUREC_IMAGE=nvcr.io/nvidia/nre/nre-ga:26.04
MODE=trainval
DATASET_DIR=outputs/ncore_dense_lidar_sweeps_v1/scene-0061
DATASET_PATH=scene-0061.json
OUTPUT_DIR=outputs/nurec_formal_scene0061_dense_lidar_sweeps_v1_6cam_40k_attempt_001
CACHE_DIR=.cache/nurec

CAMERA_IDS=camera_front,camera_front_left,camera_front_right,camera_back,camera_back_left,camera_back_right
LIDAR_IDS=lidar_top

# nuScenes does not provide the dedicated Hyperion validation cameras named by
# the base recipe. Validate on all available training trajectories instead.
# Metrics are therefore reconstruction-fit metrics, not held-out generalization.
VAL_CAMERA_IDS=camera_front,camera_front_left,camera_front_right,camera_back,camera_back_left,camera_back_right
VAL_LIDAR_IDS=lidar_top

CONFIG_NAME=configs/apps/prod/Hyperion-8.1/car2sim_6cam.yaml
MAX_EPOCHS=1
# The official six-camera config uses 40k samples. Keeping that value lets its
# add/relocate schedule finish at 35k instead of truncating densification.
SAMPLES_PER_EPOCH=40000

# The host has 59 GiB RAM, so the documented 64g shm mount is impossible.
# 40g remains below the launcher's 80%-of-RAM safety guard.
SHM_SIZE=40g
GPUS=all
CUDA_VISIBLE_DEVICES=0

# nuScenes human annotations are stored as EXTERNAL. The formal pipeline must
# accept that source explicitly and prove usable vehicle/pedestrian tracks
# before starting the expensive reconstruction.
TRACK_LABEL_SOURCES=EXTERNAL
REQUIRE_DYNAMIC_TRACKS=1
NCORE_VALIDATION_IMAGE=nsb/ncore-converter:2026-07-17-dense-v1
EXPECTED_MIN_USDZ_TRACKS=2
EXPECTED_MIN_USDZ_VEHICLES=1
EXPECTED_MIN_USDZ_PEDESTRIANS=1

# Acceptance and observability. A formal attempt must contain exactly one
# NuRec run and its checkpoint/config must match the 40k recipe.
EXPECTED_CAMERA_IDS=camera_front,camera_front_left,camera_front_right,camera_back,camera_back_left,camera_back_right
EXPECTED_GLOBAL_STEP=40000
EXPECTED_SAMPLES_PER_EPOCH=40000
EXPECTED_MAX_EPOCHS=1
REQUIRE_SINGLE_RUN=1
RESOURCE_MONITOR_INTERVAL_SECONDS=1
