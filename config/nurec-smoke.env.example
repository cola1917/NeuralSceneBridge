# Copy to config/nurec-smoke.env on the Ubuntu server and adjust paths after
# NCore conversion. Do not place NGC_API_KEY in this file.

NUREC_IMAGE=nvcr.io/nvidia/nre/nre-ga:26.04
DATASET_DIR=outputs/ncore
DATASET_PATH=scene-0061.json
OUTPUT_DIR=outputs/nurec_smoke

# Start with the three forward cameras on a 24-32 GB smoke-test GPU.
# For the full six-camera run use:
# camera_front,camera_front_left,camera_front_right,camera_back,camera_back_left,camera_back_right
CAMERA_IDS=camera_front,camera_front_left,camera_front_right
LIDAR_IDS=lidar_top

CONFIG_NAME=configs/apps/prod/Hyperion-8.1/car2sim_6cam.yaml
MAX_EPOCHS=1
SAMPLES_PER_EPOCH=10
SHM_SIZE=32g
GPUS=all
CUDA_VISIBLE_DEVICES=0
