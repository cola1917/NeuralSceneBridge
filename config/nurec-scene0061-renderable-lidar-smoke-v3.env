# scene-0061 renderable-LiDAR architecture smoke. This output is never used as
# final acceptance evidence; it exists to prove the recipe can export a USDZ
# whose live SensorsimService returns non-empty RGB and LiDAR responses before
# spending a full 40k run.

NUREC_IMAGE=nvcr.io/nvidia/nre/nre-ga:26.04
MODE=trainval
DATASET_DIR=outputs/ncore_dense_lidar_sweeps_v2/scene-0061
DATASET_PATH=scene-0061.json
OUTPUT_DIR=outputs/nurec_scene0061_renderable_lidar_v3_6cam_100step_smoke_attempt_001
CACHE_DIR=.cache/nurec

CAMERA_IDS=camera_front,camera_front_left,camera_front_right,camera_back,camera_back_left,camera_back_right
LIDAR_IDS=lidar_top
VAL_CAMERA_IDS=camera_front
VAL_LIDAR_IDS=lidar_top
VAL_LIDAR=1

CONFIG_NAME=configs/apps/prod/Hyperion-8.1/car2sim_6cam.yaml
MAX_EPOCHS=1
SAMPLES_PER_EPOCH=100
SHM_SIZE=40g
GPUS=all
CUDA_VISIBLE_DEVICES=0

TRACK_LABEL_SOURCES=EXTERNAL
REQUIRE_DYNAMIC_TRACKS=1
NCORE_VALIDATION_IMAGE=nsb/ncore-converter:2026-07-17-dense-v1

REQUIRE_LIDAR_SUPERVISION=1
REQUIRE_RENDERABLE_LIDAR=1
N_TRAIN_SAMPLE_LIDAR_RAYS=2048
RATIO_LIDAR_SAMPLES=1.0
LIDAR_LOSS_WEIGHT=0.005
LIDAR_INTENSITY_LOSS_WEIGHT=1.0
LIDAR_RAYDROP_LOSS_WEIGHT=0.1

EXPECTED_CAMERA_IDS=camera_front,camera_front_left,camera_front_right,camera_back,camera_back_left,camera_back_right
EXPECTED_LIDAR_IDS=lidar_top
EXPECTED_MIN_LIDAR_RAYS=2048
EXPECTED_MIN_LIDAR_SAMPLE_RATIO=1.0
EXPECTED_MIN_LIDAR_LOSS_WEIGHT=0.005
EXPECTED_MIN_LIDAR_EXTRA_SIGNAL_DIM=3
EXPECTED_MIN_LIDAR_INTENSITY_LOSS_WEIGHT=1.0
EXPECTED_MIN_LIDAR_RAYDROP_LOSS_WEIGHT=0.1
EXPECTED_VAL_LIDAR=1
EXPECTED_GLOBAL_STEP=100
EXPECTED_SAMPLES_PER_EPOCH=100
EXPECTED_MAX_EPOCHS=1
EXPECTED_MIN_USDZ_TRACKS=2
EXPECTED_MIN_USDZ_VEHICLES=1
EXPECTED_MIN_USDZ_PEDESTRIANS=1
REQUIRE_SINGLE_RUN=1
RESOURCE_MONITOR_INTERVAL_SECONDS=1

